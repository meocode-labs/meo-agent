{
  "name": "meo-agent",
  "version": "1.0.1",
  "description": "Wget-like CLI for downloading files via HTTP/HTTPS, distributed as a single static binary via @yao-pkg/pkg and GitHub Actions release workflow.",
  "main": "index.js",
  "bin": {
    "meo-agent": "./index.js"
  },
  "scripts": {
    "build": "yao-pkg ."
  },
  "pkg": {
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ],
    "outputPath": "dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meocode-labs/meo-agent.git"
  },
  "bugs": {
    "url": "https://github.com/meocode-labs/meo-agent/issues"
  },
  "homepage": "https://github.com/meocode-labs/meo-agent#readme",
  "author": {
    "name": "penadidik"
  },
  "license": "MIT",
  "keywords": [
    "wget",
    "cli",
    "downloader",
    "http",
    "https",
    "download",
    "terminal"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}